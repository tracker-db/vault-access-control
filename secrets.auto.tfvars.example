# secrets.auto.tfvars
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SENSITIVE VALUES — DO NOT COMMIT THIS FILE
# This file is in .gitignore.
#
# Copy secrets.auto.tfvars.example → secrets.auto.tfvars
# Fill in real values before running terraform plan/apply.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vault_addr = "https://vault.nextresearch.io"

anydesk_server_1 = {
  anydesk_id = "CHANGE_ME"
  password   = "CHANGE_ME"
  hostname   = "anydesk-blue.lab.internal"
}

anydesk_server_2 = {
  anydesk_id = "CHANGE_ME"
  password   = "CHANGE_ME"
  hostname   = "anydesk-green.lab.internal"
}

app_service_password        = "CHANGE_ME"
app_service_ssh_private_key = ""

# Note: user account passwords are NOT managed by Terraform.
# Set initial passwords manually after first apply:
#   vault write auth/userpass/users/<name> password=<password>
# Users change their own passwords going forward.
