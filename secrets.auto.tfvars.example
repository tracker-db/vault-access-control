# secrets.auto.tfvars
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SENSITIVE VALUES — DO NOT COMMIT (gitignored)
#
# Copy this file to secrets.auto.tfvars and fill in real values.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vault_addr = "https://vault.nextresearch.io"

# ── AnyDesk Servers ─────────────────────────────────────
# anydesk_id: the 9-digit ID shown in the AnyDesk UI on each server
# password:   the AnyDesk incoming-connection password

anydesk_server_1 = {
  anydesk_id = "CHANGE_ME"   # open AnyDesk on anydesk-blue to find this ID
  password   = "CHANGE_ME"
  hostname   = "anydesk-blue.lab.internal"
}

anydesk_server_2 = {
  anydesk_id = "CHANGE_ME"   # open AnyDesk on anydesk-green to find this ID
  password   = "CHANGE_ME"
  hostname   = "anydesk-green.lab.internal"
}

# ── Shared Service Account ───────────────────────────────
# OS-level credentials used after bastion hop to reach internal systems.
# username is controlled by app_service_username variable (default: ej)

app_service_password        = "CHANGE_ME"
app_service_ssh_private_key = ""

# Note: user account passwords are NOT managed by Terraform.
# Set initial passwords once via:  vault write auth/userpass/users/<name> password=X
